**Code Explanation:**

This script loads all four trained SAC models and evaluates them across fixed latency levels (0, 1, 2, 3, 5 steps) with 10 deterministic episodes each. The `LatencyWrapper` and `ObservationAugmenter` classes are imported from `step_1.py`. For each (condition, latency) pair, we build the appropriate evaluation environment, run 10 episodes collecting total returns, then compute mean and std. Results are saved as a CSV and printed as a formatted table.

**Python Code:**

```python
import sys
import os
sys.path.insert(0, os.path.abspath("codebase"))

import numpy as np
import pandas as pd
import gymnasium as gym
from stable_baselines3 import SAC
from stable_baselines3.common.monitor import Monitor
import warnings
warnings.filterwarnings('ignore')

from step_1 import LatencyWrapper, ObservationAugmenter, MAX_DELAY

DATA_DIR = 'data/'
LATENCY_LEVELS = [0, 1, 2, 3, 5]
N_EVAL_EPISODES = 10
SEED = 42


def run_episodes(model, env, n_episodes=10):
    """
    Run n_episodes deterministic episodes in env using model.

    Parameters
    ----------
    model : stable_baselines3.SAC
        Trained SAC model with deterministic=True predict.
    env : gymnasium.Env
        Evaluation environment (already wrapped appropriately).
    n_episodes : int
        Number of episodes to run.

    Returns
    -------
    returns : list of float
        Total undiscounted return for each episode.
    """
    returns = []
    for ep in range(n_episodes):
        obs, _ = env.reset(seed=SEED + ep)
        done = False
        total_reward = 0.0
        while not done:
            action, _ = model.predict(obs, deterministic=True)
            obs, reward, terminated, truncated, _ = env.step(action)
            total_reward += reward
            done = terminated or truncated
        returns.append(total_reward)
    return returns


def make_gold_eval_env(latency):
    """
    Build evaluation environment for Gold Standard: LatencyWrapper only, 17-dim obs.

    Parameters
    ----------
    latency : int
        Fixed delay in steps to inject.

    Returns
    -------
    env : gymnasium.Env
        Wrapped environment with fixed latency, no observation augmentation.
    """
    base = gym.make('HalfCheetah-v4')
    lat = LatencyWrapper(base, initial_delay=latency)
    return lat


def make_augmented_eval_env(latency, k):
    """
    Build evaluation environment for augmented conditions: LatencyWrapper + ObservationAugmenter.

    Parameters
    ----------
    latency : int
        Fixed delay in steps to inject.
    k : int
        Number of past actions to concatenate (0, 3, or 10).

    Returns
    -------
    env : gymnasium.Env
        Wrapped environment with fixed latency and 77-dim augmented observation.
    """
    base = gym.make('HalfCheetah-v4')
    lat = LatencyWrapper(base, initial_delay=latency)
    aug = ObservationAugmenter(lat, k=k)
    return aug


def evaluate_condition(model, make_env_fn, latency_levels, n_episodes):
    """
    Evaluate a model across multiple latency levels.

    Parameters
    ----------
    model : stable_baselines3.SAC
        Trained SAC model.
    make_env_fn : callable
        Function taking latency (int) and returning a gymnasium.Env.
    latency_levels : list of int
        Latency values to evaluate at.
    n_episodes : int
        Number of episodes per latency level.

    Returns
    -------
    results : dict
        Keys are latency levels, values are dicts with 'mean' and 'std' of returns.
    """
    results = {}
    for lat in latency_levels:
        env = make_env_fn(lat)
        ep_returns = run_episodes(model, env, n_episodes)
        env.close()
        results[lat] = {
            'mean': float(np.mean(ep_returns)),
            'std': float(np.std(ep_returns))
        }
    return results


if __name__ == '__main__':
    np.random.seed(SEED)

    gold_model_path = os.path.join(DATA_DIR, 'gold_model.zip')
    cond_a_model_path = os.path.join(DATA_DIR, 'cond_a_model.zip')
    cond_b_model_path = os.path.join(DATA_DIR, 'cond_B_k3_model.zip')
    cond_c_model_path = os.path.join(DATA_DIR, 'cond_C_k10_model.zip')

    print('Loading models...')
    gold_model = SAC.load(gold_model_path, device='cuda')
    cond_a_model = SAC.load(cond_a_model_path, device='cuda')
    cond_b_model = SAC.load(cond_b_model_path, device='cuda')
    cond_c_model = SAC.load(cond_c_model_path, device='cuda')
    print('All models loaded.')

    print('Evaluating Gold Standard...')
    gold_results = evaluate_condition(
        gold_model,
        lambda lat: make_gold_eval_env(lat),
        LATENCY_LEVELS,
        N_EVAL_EPISODES
    )

    print('Evaluating Condition A (k=0, padded baseline)...')
    cond_a_results = evaluate_condition(
        cond_a_model,
        lambda lat: make_augmented_eval_env(lat, k=0),
        LATENCY_LEVELS,
        N_EVAL_EPISODES
    )

    print('Evaluating Condition B (k=3, history)...')
    cond_b_results = evaluate_condition(
        cond_b_model,
        lambda lat: make_augmented_eval_env(lat, k=3),
        LATENCY_LEVELS,
        N_EVAL_EPISODES
    )

    print('Evaluating Condition C (k=10, history)...')
    cond_c_results = evaluate_condition(
        cond_c_model,
        lambda lat: make_augmented_eval_env(lat, k=10),
        LATENCY_LEVELS,
        N_EVAL_EPISODES
    )

    conditions = {
        'Gold Standard (k=0, no latency training)': gold_results,
        'Condition A (k=0, padded, curriculum)': cond_a_results,
        'Condition B (k=3, history, curriculum)': cond_b_results,
        'Condition C (k=10, history, curriculum)': cond_c_results,
    }

    rows = []
    for cond_name, res in conditions.items():
        for lat in LATENCY_LEVELS:
            rows.append({
                'condition': cond_name,
                'latency': lat,
                'mean_return': res[lat]['mean'],
                'std_return': res[lat]['std']
            })

    df = pd.DataFrame(rows)
    csv_path = os.path.join(DATA_DIR, 'robustness_results.csv')
    df.to_csv(csv_path, index=False)
    print('Robustness results saved to ' + csv_path)

    print('\n' + '='*80)
    print('ROBUSTNESS EVALUATION TABLE: Mean Return +/- Std across Latency Levels')
    print('='*80)

    header = '{:<45s}'.format('Condition') + ''.join(['{:>14s}'.format('Lat=' + str(l)) for l in LATENCY_LEVELS])
    print(header)
    print('-'*80)

    for cond_name, res in conditions.items():
        row_str = '{:<45s}'.format(cond_name[:44])
        for lat in LATENCY_LEVELS:
            cell = str(round(res[lat]['mean'], 1)) + '+/-' + str(round(res[lat]['std'], 1))
            row_str += '{:>14s}'.format(cell)
        print(row_str)

    print('='*80)

    print('\nDetailed Results:')
    for cond_name, res in conditions.items():
        print('\n' + cond_name)
        for lat in LATENCY_LEVELS:
            print('  Latency=' + str(lat) + ' steps: mean=' + str(round(res[lat]['mean'], 2)) + ', std=' + str(round(res[lat]['std'], 2)))
```

